[user]
	name = Paolo Gatti (pgi)
	email = pgi@odoo.com
[core]
	editor = nvim
[pull]
	rebase = true
	autoSetupRemote = true
	default = current
	autoSetupRemote = true
[log]
	abbrevCommit = true
[push]
	autoSetupRemote = true
	default = current
[init]
	defaultBranch = main
[alias]
	amend = commit --amend --no-edit
	l = log --oneline
	pf = push --force-with-lease
