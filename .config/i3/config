# Base config
font pango: Aporetic Sans Mono 14
workspace_layout default
set $mod Mod4
floating_modifier $mod

# Workspaces
set $ws1 "1:  🌍  "
set $ws2 "2:  💬  "
set $ws3 "3:  📧𝄢  "
set $ws4 "4:  ⌨  "
set $ws5 "5:  🖌️  "
set $ws6 "6:  📂  "
set $ws7 "7:  🔑  "
set $ws8 "8:  "
set $ws9 "9: "
set $ws10 "10: "

# Assign to workspace
assign [class="(?i)librewolf"]     $ws1
assign [class="(?i)discord"]       $ws2
assign [class="(?i)Thunderbird"]   $ws3
assign [class="(?i)Spotify"]       $ws3
assign [class="(?i)st"]            $ws4
assign [class="(?i)gimp"]          $ws5
assign [class="Thunar"]            $ws6
assign [class="(?i)keepassxc"]     $ws7

# beep off
exec --no-startup-id xset b off

# notifications
exec --no-startup-id dbus-launch dunst --config ~/.config/dunst/dunstrc 

# tray
exec --no-startup-id /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec --no-startup-id greenclip daemon
exec --no-startup-id blueberry-tray
exec --no-startup-id maestral start
exec --no-startup-id nm-applet

# Startup
exec --no-startup-id nitrogen --restore
exec --no-startup-id librewolf
exec --no-startup-id dropbox
exec --no-startup-id screenkey
exec --no-startup-id thunar
exec --no-startup-id thunderbird
exec --no-startup-id keepassxc
exec --no-startup-id st -e nvim --listen ~/.cache/nvim/server.pipe +terminal
exec --no-startup-id sleep 5 && ~/projects/scripts/keyboard.sh
exec --no-startup-id sleep 5 && autokey-gtk
exec --no-startup-id sleep 5 && warpd
exec --no-startup-id sleep 7 && ~/projects/scripts/discord_update_launch.sh

# Taskbar
bar {
    font pango: Aporetic Sans Mono 14
    status_command i3blocks -c ~/.config/i3/i3blocks.conf
    position bottom
    tray_output primary
    padding 4px 0px 0px 0px
    strip_workspace_numbers yes
    colors {
        separator          $purple
        background         $darkgrey
        statusline         $white
        focused_workspace  $mediumgrey   $grey       $darkgrey  $purple
        active_workspace   $lightblue    $mediumgrey $darkgrey  $purple
        inactive_workspace $darkgrey     $darkgrey   $grey      $purple
        urgent_workspace   $urgentred    $urgentred  $white     $purple
    }}

mode "resize" {
    bindsym h     resize grow   width  5 px or 1 ppt
    bindsym l     resize shrink width  5 px or 1 ppt
    bindsym j     resize grow   height 5 px or 1 ppt
    bindsym k     resize shrink height 5 px or 1 ppt
    bindsym Left  resize grow   width  5 px or 1 ppt
    bindsym Right resize shrink width  5 px or 1 ppt
    bindsym Down  resize shrink height 5 px or 1 ppt
    bindsym Up    resize grow   height 5 px or 1 ppt
    bindsym Return mode "default"
    bindsym Escape mode "default"
}

# Colors
set $darkbluetrans                #08052b
set $darkblue                     #08052b
set $lightblue                    #5294e2
set $urgentred                    #e53935
set $white                        #ffffff
set $black                        #000000
set $purple                       #e345ff
set $darkgrey                     #383c4a
set $grey                         #b0b5bd
set $mediumgrey                   #8b8b8b
set $yellowbrown                  #e1b700

#class                            border      bground     text     indicator     child_border
client.focused                    $black      $darkblue   $white   $mediumgrey   $black
client.unfocused                  $black      $darkblue   $grey    $darkgrey     $black
client.focused_inactive           $black      $darkblue   $grey    $black        $black
client.urgent                     $urgentred  $urgentred  $white   $yellowbrown  $black

# Workspace keys
bindsym $mod+1                    workspace $ws1
bindsym $mod+2                    workspace $ws2
bindsym $mod+3                    workspace $ws3
bindsym $mod+4                    workspace $ws4
bindsym $mod+5                    workspace $ws5
bindsym $mod+6                    workspace $ws6
bindsym $mod+7                    workspace $ws7
bindsym $mod+8                    workspace $ws8
bindsym $mod+9                    workspace $ws9
bindsym $mod+0                    workspace $ws10
bindsym $mod+Shift+1              move container to workspace $ws1
bindsym $mod+Shift+2              move container to workspace $ws2
bindsym $mod+Shift+3              move container to workspace $ws3
bindsym $mod+Shift+4              move container to workspace $ws4
bindsym $mod+Shift+5              move container to workspace $ws5
bindsym $mod+Shift+6              move container to workspace $ws6
bindsym $mod+Shift+7              move container to workspace $ws7
bindsym $mod+Shift+8              move container to workspace $ws8
bindsym $mod+Shift+9              move container to workspace $ws9
bindsym $mod+Shift+0              move container to workspace $ws10
bindsym $mod+Left                 focus left
bindsym $mod+Down                 focus down
bindsym $mod+Up                   focus up
bindsym $mod+Right                focus right
bindsym $mod+Shift+Left           move left
bindsym $mod+Shift+Down           move down
bindsym $mod+Shift+Up             move up
bindsym $mod+Shift+Right          move right
bindsym $mod+f                    fullscreen toggle
bindsym $mod+s                    layout stacking
bindsym $mod+g                    layout tabbed
bindsym $mod+e                    layout toggle split
bindsym $mod+Shift+space          floating toggle
bindsym $mod+space                focus mode_toggle

# i3 Keys
bindsym $mod+Shift+w              kill
bindsym $mod+Shift+c              reload
bindsym $mod+Shift+r              restart
bindsym $mod+r                    mode "resize"

# Custom Keys
bindsym Print                     exec scrot $HOME/images/%Y%m%d_%H%M%S_screenshot.png -e 'gimp $f'
bindsym $mod+l                    exec i3lock -e -i $HOME/images/wallpapers/matrimonio.png
bindsym $mod+d                    exec rofi -terminal st -modi drun -show drun -config ~/.config/rofi/config.rasi
bindsym $mod+Shift+p              exec ~/.config/i3/scripts/power-profiles
bindsym $mod+q                    exec ~/.config/i3/scripts/powermenu
bindsym $mod+p                    exec rofi -modi "clipboard:greenclip print" -show clipboard -run-command '{cmd}'
bindsym $mod+m                    exec rofi-autorandr -modi drun -show drun
bindsym $mod+t                    exec rofi-theme-selector

# System keys
bindsym XF86AudioLowerVolume      exec ~/projects/volume.sh -10% && pkill -RTMIN+1 i3blocks
bindsym XF86AudioRaiseVolume      exec ~/projects/volume.sh +10% && pkill -RTMIN+1 i3blocks
bindsym XF86AudioMute             exec ~/projects/mute.sh && pkill -RTMIN+1 i3blocks
bindsym XF86AudioPlay             exec playerctl play
bindsym XF86AudioPause            exec playerctl pause
bindsym XF86AudioNext             exec playerctl next
bindsym XF86AudioPrev             exec playerctl previous
bindsym XF86MonBrightnessUp       exec xbacklight +5 && notify-send "Brightness - $(xbacklight -get | cut -d '.' -f 1)%"
bindsym XF86MonBrightnessDown     exec xbacklight -5 && notify-send "Brightness - $(xbacklight -get | cut -d '.' -f 1)%"
